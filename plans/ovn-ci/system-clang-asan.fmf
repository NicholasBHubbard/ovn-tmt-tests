summary: OVN system tests with clang+ASAN

environment+:
  OTT_MAKE_CHECK_TARGET: check-kernel
  OTT_CC: clang
  OTT_CONFIGURE_FLAGS: "--enable-address-sanitizer"

provision:
  - how: virtual
    image: fedora

prepare+:
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml
  - how: ansible
    playbook: playbooks/ovn-system-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/ovn-make-check
