summary: OVN unit tests with gcc and jemalloc

environment+:
  OTT_CONFIGURE_FLAGS: "LIBS=-ljemalloc"

provision:
  - how: container
    image: fedora

prepare+<:
  - how: install
    package:
      - jemalloc-devel

prepare+:
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/ovn-ci/make-check
