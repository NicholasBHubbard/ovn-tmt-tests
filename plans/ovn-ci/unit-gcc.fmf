summary: OVN unit tests with gcc

provision:
  - how: container
    image: fedora

prepare:
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=git -e ovn_cc=gcc'
  - how: ansible
    playbook: playbooks/make-check.yml
    extra-args: '-e make_check_source_dir=/usr/src/ovn'

discover:
  how: fmf
  test:
    - /tests/ovn-make-check

execute:
  how: tmt
