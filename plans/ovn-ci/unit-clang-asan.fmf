summary: OVN unit tests with clang+ASAN

environment+:
  OTT_CC: clang
  OTT_CONFIGURE_FLAGS: "--enable-address-sanitizer"

provision:
  - how: container
    image: fedora

prepare+:
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/ovn-ci/make-check
