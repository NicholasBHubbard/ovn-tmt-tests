summary: OVN system-userspace tests with gcc

environment+:
  OTT_MAKE_CHECK_TARGET: check-system-userspace

provision:
  - how: virtual
    image: fedora

prepare+:
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml
  - how: ansible
    playbook: playbooks/ovn-system-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/build/make-check
