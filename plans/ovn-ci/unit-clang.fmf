summary: OVN unit tests with clang

environment+:
  MAKE_CHECK_TESTSUITEFLAGS: ""
  OVN_CC: clang

provision:
  - how: container
    image: fedora

prepare+:
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/ovn-make-check

execute:
  how: tmt
