summary: Measure incremental OVN pod and service convergence
enabled: true

environment+:
  OTT_SCALE_INITIAL_PODS: "4"
  OTT_SCALE_ITERATIONS: "2"
  OTT_SCALE_PODS_PER_SERVICE: "2"
  OTT_SCALE_LB_PROTOCOLS: tcp,udp,sctp

discover:
  how: fmf
  where: [central]
  adjust-tests:
    - duration: $OTT_SCALE_DURATION
  test:
    - /tests/scale/density-heavy
