summary: Base configuration for OVN scale workloads

environment+:
  OTT_SCALE_DURATION: 10m
  OTT_SCALE_TIMEOUT: "60"
  OTT_SCALE_IPV4: "true"
  OTT_SCALE_IPV6: "true"
  OTT_SCALE_MTU: "1342"

provision:
  - name: central
    role: central
    how: virtual
    image: fedora
    connection: system
  - name: compute-1
    role: compute
    how: virtual
    image: fedora
    connection: system
  - name: compute-2
    role: compute
    how: virtual
    image: fedora
    connection: system

prepare+:
  - name: Install scale workload dependencies
    how: install
    order: 20
    where: [compute]
    package:
      - iproute
      - iputils
