summary: Verify packet-level gateway and NAT connectivity

provision:
  - name: central
    role: central
    how: virtual
    image: fedora
    connection: system
  - name: compute-1
    role: compute
    how: virtual
    image: fedora
    connection: system
  - name: gateway-1
    role: gateway
    how: virtual
    image: fedora
    connection: system

prepare+:
  - name: Set up gateway NAT test scenario
    how: ansible
    order: 80
    playbook: tests/ovn-fake-multinode/gateway-nat/setup.yml

discover:
  - name: compute
    how: fmf
    where: compute
    test:
      - /tests/ovn-fake-multinode/gateway-nat
  - name: gateway
    how: fmf
    where: gateway
    test:
      - /tests/ovn-fake-multinode/gateway-nat
