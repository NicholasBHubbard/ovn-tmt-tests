summary: Test ovn-central role on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest ./tests/self/ovn-central/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-central.yml
    extra-args: '-e ovn_install_method=distro -e ovs_setup_install_method=distro'
