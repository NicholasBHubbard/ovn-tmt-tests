summary: Test ovn-central role on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    script: ./tests/self/ovn-central/pre.sh
  - how: ansible
    playbook: playbooks/ovn-central.yml
    extra-args: '-e install_method=package'

discover:
  how: fmf
  test:
    - /tests/self/ovn-central

execute:
  how: tmt
