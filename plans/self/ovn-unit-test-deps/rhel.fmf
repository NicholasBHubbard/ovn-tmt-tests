summary: Test OVN unit test deps on RHEL

provision:
  - how: container
    image: registry.access.redhat.com/ubi9/ubi

prepare:
  - how: shell
    script: ./tests/self/ovn-unit-test-deps/pre.sh
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/self/ovn-unit-test-deps

execute:
  how: tmt
