summary: Test OVN unit test deps on RHEL

provision:
  - how: virtual
    image: centos-stream

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest ./tests/self/ovn-unit-test-deps/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-unit-test-deps.yml
