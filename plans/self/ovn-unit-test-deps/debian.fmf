summary: Test OVN unit test deps on Debian

provision:
  - how: virtual
    image: debian

prepare:
  - how: shell
    script: ./tests/self/ovn-unit-test-deps/pre.sh
  - how: ansible
    playbook: playbooks/ovn-unit-test-deps.yml

discover:
  how: fmf
  test:
    - /tests/self/ovn-unit-test-deps

execute:
  how: tmt
