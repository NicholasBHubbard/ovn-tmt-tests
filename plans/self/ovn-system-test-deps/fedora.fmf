summary: Test OVN system test deps on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ovn-system-test-deps/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-system-test-deps.yml
