summary: Test OVN system test deps on Debian

provision:
  - how: virtual
    image: debian

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest ./tests/self/ovn-system-test-deps/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-system-test-deps.yml
