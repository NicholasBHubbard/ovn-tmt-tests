summary: Test ovn-central role with SSL on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    script: ./tests/self/ovn-central-ssl/pre.sh
  - how: shell
    script: ./tests/self/ovn-central-ssl/prepare.sh
  - how: ansible
    playbook: playbooks/ovn-central.yml
    extra-args: '-e ovn_install_method=distro -e ovs_setup_install_method=distro -e ovn_central_ssl_enabled=true'
