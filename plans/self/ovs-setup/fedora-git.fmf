summary: Test ovs-setup role with git method on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    script: ./tests/self/ovs-setup/pre.sh
  - how: ansible
    playbook: playbooks/ovs-setup.yml
    extra-args: '-e ovs_install_method=git'

discover:
  how: fmf
  test:
    - /tests/self/ovs-setup

execute:
  how: tmt
