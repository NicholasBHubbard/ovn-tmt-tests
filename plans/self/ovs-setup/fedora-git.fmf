summary: Test ovs-setup role with git method on Fedora

provision:
  - how: virtual
    image: fedora

prepare+:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ovs-setup/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovs-setup.yml
    extra-args: '-e ovs_setup_install_method=git'
