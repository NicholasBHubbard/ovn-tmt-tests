summary: Test ovn-install role with distro method on Debian

provision:
  - how: virtual
    image: debian

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ovn-install/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=distro'
