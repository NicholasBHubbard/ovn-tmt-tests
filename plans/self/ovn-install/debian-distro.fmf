summary: Test ovn-install role with distro method on Debian

provision:
  - how: container
    image: debian:latest

prepare:
  - how: install
    package:
      - sudo
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=distro'

discover:
  how: fmf
  test:
    - /tests/self/ovn-install

execute:
  how: tmt
