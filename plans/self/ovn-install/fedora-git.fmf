summary: Test ovn-install role with git method on Fedora

provision:
  - how: container
    image: fedora:latest

prepare:
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=git'

discover:
  how: fmf
  test:
    - /tests/self/ovn-install

execute:
  how: tmt
