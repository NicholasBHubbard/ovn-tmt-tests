summary: Test ovn-install role with git method on Fedora

environment:
  EXPECT_WERROR: "true"

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    script: ./tests/self/ovn-install/pre.sh
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=git -e ovn_werror=true'
