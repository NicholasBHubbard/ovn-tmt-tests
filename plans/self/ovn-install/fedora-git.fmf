summary: Test ovn-install role with git method on Fedora

environment:
  OTT_EXPECT_WERROR: "true"

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ovn-install/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=git -e ovn_install_werror=true'
