summary: Test ovn-install role with distro method on Fedora

provision:
  - how: container
    image: fedora:latest

prepare:
  - how: shell
    script: ./tests/self/ovn-install/pre.sh
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=distro'

discover:
  how: fmf
  test:
    - /tests/self/ovn-install

execute:
  how: tmt
