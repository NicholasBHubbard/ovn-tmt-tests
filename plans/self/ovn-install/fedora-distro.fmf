summary: Test ovn-install role with distro method on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest ./tests/self/ovn-install/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=distro'
