summary: Test ovn-install role with package file method on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ovn-install/test.py::TestPreconditions
  - how: ansible
    order: 90
    playbook: tests/self/ovn-install/package-fixture.yml
  - how: ansible
    order: 100
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=package -e ovn_install_package_dir=/tmp/ovn-packages'
