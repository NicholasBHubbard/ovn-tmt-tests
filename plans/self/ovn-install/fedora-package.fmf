summary: Test ovn-install role with package file method on Fedora

provision:
  - how: virtual
    image: fedora

prepare:
  - how: shell
    script: ./tests/self/ovn-install/pre.sh
  - how: shell
    script: ./tests/self/ovn-install/prepare-package.sh
  - how: ansible
    playbook: playbooks/ovn-install.yml
    extra-args: '-e ovn_install_method=package -e ovn_package_dir=/tmp/ovn-packages'

discover:
  how: fmf
  test:
    - /tests/self/ovn-install

execute:
  how: tmt
