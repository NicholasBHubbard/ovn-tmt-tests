summary: Base configuration for multi-host OVN topology self-tests

prepare:
  - name: Install Python prepare dependencies
    how: install
    order: 75
    where: [compute]
    package:
      - python3-pytest
      - python3-pyyaml

discover:
  how: fmf
  test:
    - /tests/self/multihost

execute:
  how: tmt
