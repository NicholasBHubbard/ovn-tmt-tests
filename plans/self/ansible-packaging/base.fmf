summary: Verify Ansible package configuration self-test

prepare:
  - how: shell
    order: 80
    script: python3 -m pytest -q -s ./tests/self/ansible-packaging/test.py::TestPreconditions

provision:
  how: local

discover:
  how: fmf
  test:
    - /tests/self/ansible-packaging

execute:
  how: tmt
